{% liquid
  assign active_bundles = app.metafields.smart_bundle.active_bundles.value
  assign ui_style_config = app.metafields.smart_bundle.ui_style_config.value
  assign sb_scope_id = 'SB_scope_progress_' | append: block.id
  assign initial_item_count = cart.item_count | default: 0
  assign milestones_json = '['
  assign milestone_count = 0
  assign style_background_color = ui_style_config.progressBackgroundColor | default: '#f3f4f6'
  assign style_fill_color = ui_style_config.progressFillColor | default: '#f59e0b'
  assign style_text_color = ui_style_config.textColor | default: '#1f2937'
  assign style_border_radius = ui_style_config.borderRadius | default: 20
  assign style_font_size = ui_style_config.fontSize | default: 16

  if active_bundles != blank
    for bundle in active_bundles
      assign bundle_size = bundle.products.size | default: 0
      if bundle_size <= 0
        continue
      endif

      assign bundle_tiers = bundle.SB_tiers | default: bundle.tiers

      if bundle_tiers != blank
        for tier in bundle_tiers
          assign minimum_sets = tier.SB_minimumQuantity | default: tier.minimumQuantity | default: tier.minimum_quantity | plus: 0
          assign discount_type = tier.SB_type | default: tier.type | default: 'percentage'
          assign discount_value = tier.SB_value | default: tier.value | plus: 0
          assign formatted_discount = discount_value | append: '%'

          if discount_type == 'fixed' or discount_type == 'fixed_amount'
            assign formatted_discount = discount_value | times: 100 | money
          endif

          if minimum_sets <= 0 or discount_value <= 0
            continue
          endif

          assign threshold = minimum_sets | times: bundle_size

          if milestone_count > 0
            assign milestones_json = milestones_json | append: ','
          endif

          assign milestones_json = milestones_json | append: '{"threshold":' | append: threshold | append: ',"label":"' | append: threshold | append: ' items","message":"Unlock ' | append: formatted_discount | append: ' off","discountValue":' | append: discount_value | append: ',"discountType":"' | append: discount_type | append: '"}'

          assign milestone_count = milestone_count | plus: 1
        endfor
      else
        assign discount_type = bundle.discountType | default: bundle.type | default: 'percentage'
        assign discount_value = bundle.discountValue | default: bundle.value | plus: 0
        assign formatted_discount = discount_value | append: '%'

        if discount_type == 'fixed' or discount_type == 'fixed_amount'
          assign formatted_discount = discount_value | times: 100 | money
        endif

        if discount_value <= 0
          continue
        endif

        if milestone_count > 0
          assign milestones_json = milestones_json | append: ','
        endif

        assign milestones_json = milestones_json | append: '{"threshold":' | append: bundle_size | append: ',"label":"' | append: bundle_size | append: ' items","message":"Unlock ' | append: formatted_discount | append: ' off","discountValue":' | append: discount_value | append: ',"discountType":"' | append: discount_type | append: '"}'

        assign milestone_count = milestone_count | plus: 1
      endif
    endfor
  endif

  assign milestones_json = milestones_json | append: ']'
%}

{% if milestone_count > 0 %}
  {{ 'sb-styling.css' | asset_url | stylesheet_tag }}
  {% render 'theme-bridge', scope_id: sb_scope_id, ui_style_config: ui_style_config %}
  <div id="{{ sb_scope_id }}" class="SB_scope SB_scope--progress">
    <section
      {{ block.shopify_attributes }}
      class="SB_cart_progress_wrapper SB_cart_progress__wrapper"
      style="
        --SB_progress-track: {{ style_background_color }};
        --SB_progress-fill: {{ style_fill_color }};
        --SB_progress-text: {{ style_text_color }};
        --SB_progress-radius: {{ style_border_radius }}px;
        --SB_progress-font-size: {{ style_font_size }}px;
      "
    >
      {% render 'sb-cart-progress',
        milestones: milestones_json,
        initial_item_count: initial_item_count
      %}
    </section>
  </div>
{% endif %}

{% schema %}
{
  "name": "Cart Progress Bar",
  "target": "section",
  "stylesheet": "sb-cart-progress.css",
  "javascript": "sb-cart-progress.js",
  "settings": []
}
{% endschema %}
