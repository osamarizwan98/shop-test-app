{% if product != blank and request.page_type == 'product' %}
<div
  id="sb-fbt-root"
  data-product-id="{{ product.id }}"
  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
  data-product-title="{{ product.title | escape }}"
  data-product-price="{{ product.selected_or_first_available_variant.price }}"
  data-product-image="{{ product.featured_image | img_url: '300x300' | default: '' }}"
></div>

<script>
  window.SB_APP_URL = "{{ app.url }}";
</script>
<script src="{{ 'sb-fbt.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "Frequently Bought Together",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}
