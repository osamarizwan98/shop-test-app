{% liquid
  assign active_bundles = app.metafields.smart_bundle.active_bundles.value
  assign ui_style_config = app.metafields.smart_bundle.ui_style_config.value
  assign current_product_numeric = product.id | append: ''
  assign current_product_gid = current_product_numeric | prepend: 'gid://shopify/Product/'
  assign matched_bundle = blank
  assign style_button_color = ui_style_config.buttonColor | default: '#2f80ed'
  assign style_background_color = ui_style_config.cardBackgroundColor | default: '#fffaf4'
  assign style_badge_color = ui_style_config.badgeColor | default: '#b85c38'
  assign style_text_color = ui_style_config.textColor | default: '#24170f'
  assign style_font_size = ui_style_config.fontSize | default: 16
  assign style_border_radius = ui_style_config.borderRadius | default: 18
  assign style_layout_preset = ui_style_config.layoutPreset | default: 'grid'
  assign sb_scope_id = 'SB_scope_fbt_' | append: block.id

  if request.page_type != 'product' or product == blank or active_bundles == blank
    assign matched_bundle = blank
  else
    for bundle in active_bundles
      assign is_match = false
      for bundle_item in bundle.products
        assign bundle_item_product_id = bundle_item.id | default: bundle_item | append: ''
        if bundle_item_product_id == current_product_gid or bundle_item_product_id == current_product_numeric
          assign is_match = true
          break
        endif
      endfor

      if is_match
        assign matched_bundle = bundle
        break
      endif
    endfor
  endif
%}

{% if matched_bundle != blank and matched_bundle.products.size >= 2 %}
  {{ 'sb-styling.css' | asset_url | stylesheet_tag }}
  {% render 'theme-bridge', scope_id: sb_scope_id, ui_style_config: ui_style_config %}
  {% liquid
    assign total_price = 0
    assign discounted_price = 0
    assign savings_amount = 0
    assign bundle_unavailable = false
    assign variant_payload = '['
    assign display_limit = 3
    assign discount_type = matched_bundle.discountType | default: matched_bundle.type | default: 'percentage'
    assign discount_value = matched_bundle.discountValue | default: matched_bundle.value | default: 0 | plus: 0

    for bundle_item in matched_bundle.products
      assign item_product = blank
      assign item_variant = blank
      assign item_title = bundle_item.title | default: ''
      assign item_image = blank
      assign item_is_current_product = false
      assign item_product_id = bundle_item.id | default: bundle_item | append: ''
      assign raw_variant_id = bundle_item.variant_id | default: bundle_item.variantId | default: ''
      assign numeric_variant_id = raw_variant_id | append: ''

      if numeric_variant_id contains 'gid://shopify/ProductVariant/'
        assign numeric_variant_id = numeric_variant_id | split: '/' | last
      endif

      if item_product_id == current_product_gid or item_product_id == current_product_numeric
        assign item_product = product
        assign item_is_current_product = true
      elsif bundle_item.handle != blank
        assign item_product = all_products[bundle_item.handle]
      endif

      if item_product != blank
        if numeric_variant_id != blank
          for variant in item_product.variants
            assign variant_id_string = variant.id | append: ''
            if variant_id_string == numeric_variant_id
              assign item_variant = variant
              break
            endif
          endfor
        endif

        if item_variant == blank and item_product.selected_or_first_available_variant != blank
          assign item_variant = item_product.selected_or_first_available_variant
        endif

        if item_title == blank
          assign item_title = item_product.title
        endif

        if item_product.featured_image != blank
          assign item_image = item_product.featured_image
        elsif item_variant != blank and item_variant.image != blank
          assign item_image = item_variant.image
        endif
      endif

      if item_product == blank or item_variant == blank or item_variant.available != true
        assign bundle_unavailable = true
      else
        assign total_price = total_price | plus: item_variant.price

        if variant_payload != '['
          assign variant_payload = variant_payload | append: ','
        endif

        assign escaped_item_title = item_title | default: item_variant.title | escape
        assign variant_payload = variant_payload | append: '{"id":"' | append: item_variant.id | append: '","quantity":1,"title":"' | append: escaped_item_title | append: '"}'
      endif

    endfor

    assign variant_payload = variant_payload | append: ']'

    if bundle_unavailable or total_price <= 0
      assign discounted_price = total_price
      assign savings_amount = 0
    elsif discount_type == 'fixed' or discount_type == 'fixed_amount'
      assign savings_amount = discount_value | times: 100
      if savings_amount > total_price
        assign savings_amount = total_price
      endif
      assign discounted_price = total_price | minus: savings_amount
    else
      assign savings_amount = total_price | times: discount_value | divided_by: 100
      assign discounted_price = total_price | minus: savings_amount
    endif

    if discounted_price < 0
      assign discounted_price = 0
    endif

    assign hidden_items_count = matched_bundle.products.size | minus: display_limit
    assign button_label = block.settings.button_text | default: 'Add bundle to cart'
    assign heading = block.settings.heading | default: 'Frequently bought together'
    assign body_text = block.settings.body_text | default: 'Add this curated bundle in one click and unlock the app discount at checkout.'

    if discount_type == 'fixed' or discount_type == 'fixed_amount'
      assign discount_label = savings_amount | money | prepend: 'Bundle savings: '
    else
      assign discount_label = discount_value | append: '% bundle savings'
    endif
  %}

  {% unless bundle_unavailable and block.settings.hide_when_unavailable %}
    <div id="{{ sb_scope_id }}" class="SB_scope SB_scope--fbt">
      <section
        {{ block.shopify_attributes }}
        class="SB_fbt_container SB_fbt__container"
        style="
          --SB_fbt-accent: {{ style_badge_color | default: block.settings.accent_color | default: '#b85c38' }};
          --SB_fbt-button-color: {{ style_button_color }};
          --SB_fbt-surface: {{ style_background_color | default: block.settings.card_background_color | default: '#fffaf4' }};
          --SB_fbt-border: {{ block.settings.border_color }};
          --SB_fbt-text: {{ style_text_color }};
          --SB_fbt-font-size: {{ style_font_size }}px;
          --SB_fbt-radius: {{ style_border_radius }}px;
        "
        data-sb-layout="{{ style_layout_preset }}"
      >
      <div class="SB_fbt_shell SB_fbt__shell">
        <div class="SB_fbt_header">
          <div>
            <p class="SB_fbt_eyebrow">SmartBundle AI</p>
            <h2 class="SB_fbt_heading">{{ heading }}</h2>
            <p class="SB_fbt_body">{{ body_text }}</p>
          </div>
        </div>

        <div class="SB_fbt_items" aria-label="Bundle items">
          {% liquid
            assign rendered_count = 0
            for bundle_item in matched_bundle.products
              if rendered_count >= display_limit
                break
              endif

              assign item_product = blank
              assign item_variant = blank
              assign item_title = bundle_item.title | default: ''
              assign item_image = blank
              assign item_is_current_product = false
              assign item_product_id = bundle_item.id | default: bundle_item | append: ''
              assign raw_variant_id = bundle_item.variant_id | default: bundle_item.variantId | default: ''
              assign numeric_variant_id = raw_variant_id | append: ''

              if numeric_variant_id contains 'gid://shopify/ProductVariant/'
                assign numeric_variant_id = numeric_variant_id | split: '/' | last
              endif

              if item_product_id == current_product_gid or item_product_id == current_product_numeric
                assign item_product = product
                assign item_is_current_product = true
              elsif bundle_item.handle != blank
                assign item_product = all_products[bundle_item.handle]
              endif

              if item_product != blank
                if numeric_variant_id != blank
                  for variant in item_product.variants
                    assign variant_id_string = variant.id | append: ''
                    if variant_id_string == numeric_variant_id
                      assign item_variant = variant
                      break
                    endif
                  endfor
                endif

                if item_variant == blank and item_product.selected_or_first_available_variant != blank
                  assign item_variant = item_product.selected_or_first_available_variant
                endif

                if item_title == blank
                  assign item_title = item_product.title
                endif

                if item_product.featured_image != blank
                  assign item_image = item_product.featured_image
                elsif item_variant != blank and item_variant.image != blank
                  assign item_image = item_variant.image
                endif
              endif

              if rendered_count > 0
                echo '<span class="SB_fbt_plus" aria-hidden="true">+</span>'
              endif

              render 'sb-fbt-product-card',
                image: item_image,
                title: item_title,
                is_current_product: item_is_current_product,
                variant_available: item_variant.available,
                price_text: item_variant.price | default: 0 | money

              assign rendered_count = rendered_count | plus: 1
            endfor
          %}

          {% if hidden_items_count > 0 %}
            <span class="SB_fbt_plus" aria-hidden="true">+</span>
            <div class="SB_fbt_more">+{{ hidden_items_count }}</div>
          {% endif %}
        </div>

        {% render 'sb-fbt-pricing-summary',
          total_price: total_price,
          discounted_price: discounted_price,
          savings_amount: savings_amount,
          discount_label: discount_label
        %}

        <div class="SB_fbt_actions">
          <button
            type="button"
            class="SB_fbt_button SB_js_fbt_add"
            data-sb-fbt-items='{{ variant_payload | escape }}'
            data-sb-default-text="{{ button_label | escape }}"
            {% if bundle_unavailable %}
              disabled
              aria-disabled="true"
            {% endif %}
          >
            {% if bundle_unavailable %}
              Bundle unavailable
            {% else %}
              {{ button_label }}
            {% endif %}
          </button>
          <p class="SB_fbt_message" role="status" aria-live="polite">
            {% if bundle_unavailable %}
              One or more bundle items are out of stock. The bundle add-to-cart action has been disabled.
            {% else %}
              Add all items together in one request using Shopify's Ajax cart.
            {% endif %}
          </p>
        </div>
      </div>
      </section>
    </div>
  {% endunless %}
{% endif %}

{% schema %}
{
  "name": "Frequently bought together",
  "target": "section",
  "stylesheet": "sb-fbt.css",
  "javascript": "sb-fbt.js",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently bought together"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text",
      "default": "Pair this product with the bundle and add everything to cart in one click."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Add bundle to cart"
    },
    {
      "type": "checkbox",
      "id": "hide_when_unavailable",
      "label": "Hide block when any bundle item is unavailable",
      "default": false
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background color",
      "default": "#fffaf4"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e7d5bf"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#b85c38"
    }
  ]
}
{% endschema %}
