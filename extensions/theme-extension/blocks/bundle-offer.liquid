{% liquid
  assign bundle_metafield = app.metafields.smart_bundle.active_bundles
  assign active_bundles = bundle_metafield.value | default: bundle_metafield
  assign can_render_context = true

  if request.page_type != 'product'
    assign can_render_context = false
  endif

  if product == blank
    assign can_render_context = false
  endif

  assign current_product_numeric = product.id | append: ''
  assign current_product_gid = 'gid://shopify/Product/' | append: current_product_numeric
  assign matched_bundle = blank
  assign hasActiveBundle = false
%}

{% if app.metafields.smart_bundle.active_bundles != blank %}
  <link
    rel="stylesheet"
    href="{{ 'smart-bundle-styles.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
  <noscript>
    <link rel="stylesheet" href="{{ 'smart-bundle-styles.css' | asset_url }}">
  </noscript>
  <script src="{{ 'bundle-logic.js' | asset_url }}" defer></script>
  <style>
    .SB_bundle_card {
      border: 0.0625rem solid var(--color-border, rgba(18, 18, 18, 0.12));
      border-radius: 0.75rem;
      padding: 1rem;
    }

    .SB_bundle_grid {
      display: grid;
      gap: 0.75rem;
      grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .SB_bundle_item {
      align-items: center;
      display: flex;
      gap: 0.75rem;
      min-width: 0;
    }

    .SB_bundle_image {
      aspect-ratio: 1 / 1;
      height: 5rem;
      object-fit: cover;
      width: 5rem;
    }
  </style>
{% endif %}

{% if can_render_context and active_bundles != blank %}
  {% for bundle in active_bundles %}
    {% assign bundle_products = bundle.products %}
    {% assign product_match_found = false %}

    {% if bundle_products != blank %}
      {% for bundle_item in bundle_products %}
        {% assign bundle_product_id = bundle_item.id | default: bundle_item | append: '' %}
        {% assign normalized_bundle_product_id = bundle_product_id %}

        {% if bundle_product_id contains 'gid://shopify/Product/' %}
          {% assign normalized_bundle_product_id = bundle_product_id | split: '/' | last %}
        {% endif %}

        {% if bundle_product_id == current_product_gid or bundle_product_id == current_product_numeric or normalized_bundle_product_id == current_product_numeric %}
          {% assign product_match_found = true %}
          {% break %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {% if product_match_found and matched_bundle == blank %}
      {% assign matched_bundle = bundle %}
      {% assign hasActiveBundle = true %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if hasActiveBundle and matched_bundle != blank %}
  {% assign quick_add_available = true %}
  {% assign discount_type = matched_bundle.discountType | default: matched_bundle.type | default: 'percentage' %}
  {% assign discount_value = matched_bundle.discountValue | default: matched_bundle.value | default: 0 | plus: 0 %}
  {% if discount_type == 'percentage' %}
    {% capture savings_text %}Save {{ discount_value }}%{% endcapture %}
  {% else %}
    {% capture savings_text %}Save {{ discount_value | money }}{% endcapture %}
  {% endif %}

  {% capture variant_ids_csv %}
    {% for bundle_item in matched_bundle.products %}
      {% assign resolved_variant_id = bundle_item.variant_id | default: bundle_item.variantId | default: '' %}
      {% assign bundle_handle = bundle_item.handle | default: '' %}

      {% if resolved_variant_id == blank and bundle_handle != blank %}
        {% assign bundle_product = all_products[bundle_handle] %}
        {% if bundle_product != blank and bundle_product.variants != blank and bundle_product.variants.size > 0 %}
          {% assign resolved_variant_id = bundle_product.selected_or_first_available_variant.id | default: bundle_product.variants.first.id %}
        {% endif %}
      {% endif %}

      {% if resolved_variant_id == blank %}
        {% assign quick_add_available = false %}
      {% else %}
        {% assign resolved_variant_id = resolved_variant_id | append: '' %}
        {% if resolved_variant_id contains 'gid://shopify/ProductVariant/' %}
          {% assign resolved_variant_id = resolved_variant_id | split: '/' | last %}
        {% endif %}
        {{ resolved_variant_id }}{% unless forloop.last %},{% endunless %}
      {% endif %}
    {% endfor %}
  {% endcapture %}

  <aside {{ block.shopify_attributes }} class="SB_bundle_card SB_bundle_card--offer">
    <header class="SB_bundle_header">
      <h3 class="SB_bundle_title">{{ block.settings.heading }}</h3>
      <span class="SB_discount_badge">Bundle & Save</span>
    </header>
    <p class="SB_price_savings">{{ savings_text }}</p>

    <ul class="SB_bundle_grid">
      {% for bundle_item in matched_bundle.products %}
        {% assign bundle_handle = bundle_item.handle | default: '' %}
        {% assign bundle_product = blank %}
        {% if bundle_handle != blank %}
          {% assign bundle_product = all_products[bundle_handle] %}
        {% endif %}

        {% assign item_title = bundle_item.title | default: bundle_product.title | default: 'Bundle item' %}
        {% assign item_price_raw = bundle_item.price | default: bundle_product.selected_or_first_available_variant.price %}
        {% assign item_image = bundle_item.image | default: bundle_product.featured_image %}

        <li class="SB_bundle_item">
          {% if item_image != blank %}
            <img
              class="SB_bundle_image"
              src="{{ item_image | image_url: width: 160 }}"
              alt="{{ item_title | escape }}"
              loading="lazy"
              decoding="async"
              width="80"
              height="80"
            >
          {% else %}
            <div class="SB_bundle_image SB_bundle_image--placeholder" aria-hidden="true"></div>
          {% endif %}

          <div class="SB_bundle_content">
            <p class="SB_bundle_product_title">{{ item_title }}</p>
            <p class="SB_bundle_price">
              {% if item_price_raw != blank %}
                {{ item_price_raw | money }}
              {% else %}
                &nbsp;
              {% endif %}
            </p>
          </div>
        </li>
      {% endfor %}
    </ul>

    {% if quick_add_available and variant_ids_csv != blank %}
      <button
        type="button"
        class="SB_bundle_button"
        style="--SB_button_color: {{ block.settings.button_color }};"
        data-variants="{{ variant_ids_csv | strip_newlines | strip | escape }}"
        data-default-text="Buy Bundle"
        onclick="addSmartBundleToCart(this)"
      >
        Buy Bundle
      </button>
    {% else %}
      <p class="SB_bundle_helper">Bundle variants are still syncing. Please refresh shortly.</p>
    {% endif %}
  </aside>
{% endif %}

{% schema %}
{
  "name": "Bundle Offer",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bundle & Save"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Color",
      "default": "#1f7a3f"
    }
  ]
}
{% endschema %}
