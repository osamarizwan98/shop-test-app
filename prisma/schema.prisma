generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

enum BundleStatus {
  active
  inactive
}

enum DiscountType {
  percentage
  fixed_amount
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Bundle {
  id            String       @id @default(uuid())
  shop          String
  title         String
  status        BundleStatus @default(active)
  discountType  DiscountType
  discountValue Float
  productIds    Json
  totalSales    Float        @default(0)
  totalRevenue  Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([shop])
}

model Analytics {
  id               String   @id @default(uuid())
  shop             String   @unique
  totalBundleSales Float    @default(0)
  totalRevenue     Float    @default(0)
  totalSavings     Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([shop])
}

model InventoryAnalysis {
  id           String   @id @default(uuid())
  shop         String
  productId    String
  lastSoldDate DateTime?
  stockLevel   Int
  isStagnant   Boolean  @default(false)

  @@index([shop])
}
