generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

enum BundleStatus {
  active
  inactive
}

enum DiscountType {
  percentage
  fixed_amount
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Bundle {
  id            String       @id @default(uuid())
  shop          String
  title         String
  status        BundleStatus @default(active)
  inventoryHidden Boolean    @default(false)
  discountType  DiscountType
  discountValue Float
  productIds    Json
  totalSales    Float        @default(0)
  totalRevenue  Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([shop])
}

model Analytics {
  id               String   @id @default(uuid())
  shop             String   @unique
  totalBundleSales Float    @default(0)
  totalRevenue     Float    @default(0)
  totalSavings     Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([shop])
}

model BundleAnalytics {
  id          String   @id @default(uuid())
  shop        String
  bundleId    String
  bundleTitle String
  views       Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  revenue     Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shop, bundleId])
  @@index([shop])
  @@index([shop, revenue])
}

model OrderAttribution {
  id               String   @id @default(uuid())
  shop             String
  orderId          String
  orderName        String?
  currency         String?
  isBundleOrder    Boolean  @default(false)
  attributedBundles Json
  grossRevenue     Float    @default(0)
  refundedAmount   Float    @default(0)
  netRevenue       Float    @default(0)
  bundleRevenue    Float    @default(0)
  nonBundleRevenue Float    @default(0)
  isCanceled       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([shop, orderId])
  @@index([shop, createdAt])
  @@index([shop, isBundleOrder])
}

model InventoryAnalysis {
  id           String   @id @default(uuid())
  shop         String
  productId    String
  lastSoldDate DateTime?
  stockLevel   Int
  isStagnant   Boolean  @default(false)

  @@index([shop])
}

model BundleStyleSettings {
  id        String   @id @default(uuid())
  shop      String   @unique
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model OnboardingState {
  id                     String   @id @default(uuid())
  shop                   String   @unique
  status                 String   @default("pending")
  seededBundleId         String?
  seededProductsCount    Int      @default(0)
  lastError              String?
  completedAt            DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([shop])
}
