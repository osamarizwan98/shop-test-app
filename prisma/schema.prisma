generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

enum BundleStatus {
  active
  inactive
}

enum DiscountType {
  percentage
  fixed_amount
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Bundle {
  id            String       @id @default(uuid())
  shop          String
  title         String
  status        BundleStatus @default(active)
  inventoryHidden Boolean    @default(false)
  discountType  DiscountType
  discountValue Float
  productIds        Json
  shopifyDiscountId String?
  totalSales    Float        @default(0)
  totalRevenue  Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([shop])
}

model Analytics {
  id               String   @id @default(uuid())
  shop             String   @unique
  totalBundleSales Float    @default(0)
  totalRevenue     Float    @default(0)
  totalSavings     Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([shop])
}

model BundleAnalytics {
  id          String   @id @default(uuid())
  shop        String
  bundleId    String
  bundleTitle String
  views       Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  revenue     Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shop, bundleId])
  @@index([shop])
  @@index([shop, revenue])
}

model OrderAttribution {
  id               String   @id @default(uuid())
  shop             String
  orderId          String
  orderName        String?
  currency         String?
  isBundleOrder    Boolean  @default(false)
  attributedBundles Json
  grossRevenue     Float    @default(0)
  refundedAmount   Float    @default(0)
  netRevenue       Float    @default(0)
  bundleRevenue    Float    @default(0)
  nonBundleRevenue Float    @default(0)
  isCanceled       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([shop, orderId])
  @@index([shop, createdAt])
  @@index([shop, isBundleOrder])
}

model InventoryAnalysis {
  id           String   @id @default(uuid())
  shop         String
  productId    String
  lastSoldDate DateTime?
  stockLevel   Int
  isStagnant   Boolean  @default(false)

  @@index([shop])
}

model BundleStyleSettings {
  id        String   @id @default(uuid())
  shop      String   @unique
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model OnboardingState {
  id                     String   @id @default(uuid())
  shop                   String   @unique
  status                 String   @default("pending")
  seededBundleId         String?
  seededProductsCount    Int      @default(0)
  lastError              String?
  completedAt            DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([shop])
}

model FbtConfig {
  id            String       @id @default(cuid())
  shop          String
  productId     String
  title         String?
  isEnabled     Boolean      @default(true)
  discountType  String       @default("none")
  discountValue Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  products      FbtProduct[]

  @@unique([shop, productId])
  @@index([shop])
}

model FbtProduct {
  id          String    @id @default(cuid())
  fbtConfigId String
  productId   String
  variantId   String?
  title       String?
  price       Float     @default(0)
  imageUrl    String?
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  fbtConfig   FbtConfig @relation(fields: [fbtConfigId], references: [id], onDelete: Cascade)

  @@index([fbtConfigId])
}

model TieredDiscount {
  id                String               @id @default(cuid())
  shop              String
  title             String
  productScope      String               @default("all")
  productIds        Json                 @default("[]")
  collectionIds     Json                 @default("[]")
  active            Boolean              @default(false)
  shopifyDiscountId String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  tiers             TieredDiscountTier[]

  @@index([shop])
}

model TieredDiscountTier {
  id               String         @id @default(cuid())
  tieredDiscountId String
  minimumQuantity  Int
  discountType     String
  discountValue    Float
  position         Int            @default(0)
  createdAt        DateTime       @default(now())
  tieredDiscount   TieredDiscount @relation(fields: [tieredDiscountId], references: [id], onDelete: Cascade)

  @@index([tieredDiscountId])
}

model ProgressBarConfig {
  id             String                 @id @default(cuid())
  shopDomain     String                 @unique
  activeOnCart   Boolean                @default(true)
  activeOnDrawer Boolean                @default(true)
  animationStyle String                 @default("smooth")
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  milestones     ProgressBarMilestone[]

  @@index([shopDomain])
}

model ProgressBarMilestone {
  id          String            @id @default(cuid())
  configId    String
  type        String
  threshold   Float
  rewardValue Float             @default(0)
  rewardLabel String            @default("")
  message     String            @default("")
  position    Int               @default(0)
  createdAt   DateTime          @default(now())
  config      ProgressBarConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
}

model AnalyticsEvent {
  id             String   @id @default(cuid())
  shopDomain     String
  event          String
  bundleId       String?
  sessionId      String?
  orderId        String?
  revenue        Float?
  discountAmount Float?
  metadata       Json?
  timestamp      DateTime @default(now())

  @@index([shopDomain, event, timestamp])
}

model CartNudgeConfig {
  id                  String   @id @default(cuid())
  shopDomain          String   @unique
  active              Boolean  @default(true)
  dismissDuration     Int      @default(24)
  maxNudgesPerSession Int      @default(1)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([shopDomain])
}
